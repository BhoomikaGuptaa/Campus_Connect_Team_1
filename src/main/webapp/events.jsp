<%@ page import="java.sql.*,db.DBConnection,util.HtmlUtil" %><%@ page contentType="text/html;charset=UTF-8" %>
<% Integer userId=(Integer)session.getAttribute("userId");if(userId==null){response.sendRedirect("login.jsp");return;}String search=request.getParameter("search");if(search==null)search="";String category=request.getParameter("category");if(category==null)category="";String location=request.getParameter("location");if(location==null)location="";String date=request.getParameter("date");if(date==null)date=""; %>
<!doctype html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Events | CampusConnect</title><link rel="stylesheet" href="css/style.css"></head><body>
<nav class="nav"><a class="brand" href="index.jsp"><img src="images/sjsu-mark.svg" alt="SJSU"><span>Campus<b>Connect</b></span></a><div class="nav-links"><a href="index.jsp">Home</a><a href="events.jsp">Events</a><a href="people">Find People</a><a href="my-events">My Events</a><a href="profile">Profile</a><a href="logout">Log out</a></div></nav>
<main class="container"><div class="section-head"><div><div class="eyebrow dark">Member access</div><h2>Explore all events</h2><p class="muted">Search by keyword, category, date, or location.</p></div></div>
<% Object fs=session.getAttribute("flashSuccess"),fe=session.getAttribute("flashError");if(fs!=null){%><div class="flash success"><%=HtmlUtil.esc(fs)%></div><%session.removeAttribute("flashSuccess");}if(fe!=null){%><div class="flash error"><%=HtmlUtil.esc(fe)%></div><%session.removeAttribute("flashError");}%>
<div class="card"><form class="filters" method="get"><input name="search" placeholder="Search events..." value="<%=HtmlUtil.esc(search)%>"><select name="category"><option value="">All categories</option><%try(Connection c=DBConnection.getConnection();PreparedStatement p=c.prepareStatement("SELECT Name FROM Categories ORDER BY Name");ResultSet r=p.executeQuery()){while(r.next()){String n=r.getString(1);%><option <%=n.equals(category)?"selected":""%>><%=HtmlUtil.esc(n)%></option><%}}catch(Exception e){}%></select><input name="location" placeholder="Location" value="<%=HtmlUtil.esc(location)%>"><input type="date" name="date" value="<%=HtmlUtil.esc(date)%>"><button class="btn">Search</button><a class="btn secondary" href="events.jsp">Clear</a></form></div>
<div class="event-list" style="margin-top:18px"><%String q="SELECT e.Event_ID,e.Title,e.Description,e.Location,e.Event_Date,e.Capacity,c.Name Category,u.First_Name,u.Last_Name,COUNT(sr.Signup_ID) registered_count,(SELECT Status FROM Signups me WHERE me.Event_ID=e.Event_ID AND me.Student_ID="+userId+") my_status,(SELECT Waitlist_Position FROM Signups me WHERE me.Event_ID=e.Event_ID AND me.Student_ID="+userId+") my_pos FROM Events e JOIN Categories c ON c.Category_ID=e.Category_ID JOIN Users u ON u.User_ID=e.Organizer_ID LEFT JOIN Signups sr ON sr.Event_ID=e.Event_ID AND sr.Status='registered' WHERE e.Is_Cancelled=0 ";if(!search.isBlank())q+="AND (e.Title LIKE ? OR e.Description LIKE ?) ";if(!category.isBlank())q+="AND c.Name=? ";if(!location.isBlank())q+="AND e.Location LIKE ? ";if(!date.isBlank())q+="AND DATE(e.Event_Date)=? ";q+="GROUP BY e.Event_ID,e.Title,e.Description,e.Location,e.Event_Date,e.Capacity,c.Name,u.First_Name,u.Last_Name ORDER BY e.Event_Date";boolean any=false;try(Connection c=DBConnection.getConnection();PreparedStatement p=c.prepareStatement(q)){int i=1;if(!search.isBlank()){p.setString(i++,"%"+search+"%");p.setString(i++,"%"+search+"%");}if(!category.isBlank())p.setString(i++,category);if(!location.isBlank())p.setString(i++,"%"+location+"%");if(!date.isBlank())p.setString(i++,date);try(ResultSet r=p.executeQuery()){while(r.next()){any=true;int left=r.getInt("Capacity")-r.getInt("registered_count");String st=r.getString("my_status");%><article class="event-card"><div><span class="badge"><%=HtmlUtil.esc(r.getString("Category"))%></span><h3><%=HtmlUtil.esc(r.getString("Title"))%></h3><p class="muted"><%=HtmlUtil.esc(r.getString("Description"))%></p><div class="meta"><span>📅 <%=new java.text.SimpleDateFormat("EEE, MMM d, yyyy h:mm a").format(r.getTimestamp("Event_Date"))%></span><span>📍 <%=HtmlUtil.esc(r.getString("Location"))%></span><span>Hosted by <%=HtmlUtil.esc(r.getString("First_Name"))%> <%=HtmlUtil.esc(r.getString("Last_Name"))%></span></div></div><div class="actions"><div class="spots"><%=left%> spots left</div><%if("registered".equals(st)){%><span class="badge registered">Registered</span><form method="post" action="signup" style="margin-top:9px"><input type="hidden" name="eventId" value="<%=r.getInt("Event_ID")%>"><input type="hidden" name="action" value="cancel"><input type="hidden" name="returnTo" value="events.jsp"><button class="btn danger">Cancel</button></form><%}else if("waitlisted".equals(st)){%><span class="badge waitlisted">Waitlist #<%=r.getInt("my_pos")%></span><form method="post" action="signup" style="margin-top:9px"><input type="hidden" name="eventId" value="<%=r.getInt("Event_ID")%>"><input type="hidden" name="action" value="cancel"><input type="hidden" name="returnTo" value="events.jsp"><button class="btn danger">Leave waitlist</button></form><%}else{%><form method="post" action="signup"><input type="hidden" name="eventId" value="<%=r.getInt("Event_ID")%>"><input type="hidden" name="returnTo" value="events.jsp"><button class="btn"><%=left>0?"Sign up":"Join waitlist"%></button></form><%}%></div></article><%}}}catch(Exception e){%><div class="flash error">Database error: <%=HtmlUtil.esc(e.getMessage())%></div><%}if(!any){%><div class="card empty"><h3>No events found</h3><p class="muted">Try clearing one or more filters.</p></div><%}%></div></main><footer class="footer">© 2026 CampusConnect — San José State University</footer></body></html>
