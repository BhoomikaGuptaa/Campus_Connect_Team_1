<%@ page import="util.HtmlUtil" %><%@ page contentType="text/html;charset=UTF-8" %>
<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Log in | CampusConnect</title><link rel="stylesheet" href="css/style.css"></head><body><nav class="nav"><a class="brand" href="index.jsp"><img src="images/sjsu-mark.svg" alt="SJSU"><span>Campus<b>Connect</b></span></a><div class="nav-links"><a href="index.jsp">Home</a><a href="events.jsp">Events</a><a href="people">Find People</a></div></nav><main class="form-shell"><div class="form-card"><div class="eyebrow" style="color:#0b4f9c">Welcome back</div><h1>Log in to CampusConnect</h1><p class="muted">Manage your event signups and student profile.</p><%if(request.getParameter("registered")!=null){%><div class="flash success">Account created. You can log in now.</div><%}if(request.getAttribute("error")!=null){%><div class="flash error"><%=HtmlUtil.esc(request.getAttribute("error"))%></div><%}%><form method="post" action="login"><label class="label">SJSU email</label><input type="email" name="email" placeholder="you@sjsu.edu" required><label class="label">Password</label><input type="password" name="password" required><button class="btn" style="width:100%;margin-top:20px">Log in</button></form><p style="text-align:center;margin-top:18px">New here? <a href="register.jsp"><b>Create an account</b></a></p><div class="card" style="margin-top:18px;background:#f7f9fc;box-shadow:none"><b>Demo student</b><br><span class="muted">brandon.phan@sjsu.edu / Password123!</span></div></div></main></body></html>
