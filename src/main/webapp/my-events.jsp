<%@ page import="java.util.*,util.HtmlUtil" %><%@ page contentType="text/html;charset=UTF-8" %><%List<Map<String,Object>> events=(List<Map<String,Object>>)request.getAttribute("events");%>
<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>My Events | CampusConnect</title><link rel="stylesheet" href="css/style.css"></head><body><nav class="nav"><a class="brand" href="index.jsp"><img src="images/sjsu-mark.svg" alt="SJSU"><span>Campus<b>Connect</b></span></a><div class="nav-links"><a href="index.jsp">Home</a><a href="events.jsp">Events</a><a href="people">Find People</a><a href="profile">Profile</a><a href="logout">Log out</a></div></nav><main class="container"><div class="section-head"><div><div class="eyebrow" style="color:#0b4f9c">FR5 — Signup history</div><h2>My events</h2><p class="muted">See registered, waitlisted, and cancelled event records.</p></div></div><%Object fs=session.getAttribute("flashSuccess"),fe=session.getAttribute("flashError");if(fs!=null){%><div class="flash success"><%=HtmlUtil.esc(fs)%></div><%session.removeAttribute("flashSuccess");}if(fe!=null){%><div class="flash error"><%=HtmlUtil.esc(fe)%></div><%session.removeAttribute("flashError");}%><div class="card table-wrap"><table class="data-table"><thead><tr><th>Event</th><th>Category</th><th>Date</th><th>Location</th><th>Status</th><th>Action</th></tr></thead><tbody><%if(events!=null&&!events.isEmpty())for(Map<String,Object> e:events){String st=String.valueOf(e.get("Status"));%><tr><td><b><%=HtmlUtil.esc(e.get("Title"))%></b></td><td><%=HtmlUtil.esc(e.get("Category"))%></td><td><%=HtmlUtil.esc(e.get("Event_Date"))%></td><td><%=HtmlUtil.esc(e.get("Location"))%></td><td><span class="badge <%=st%>"><%=HtmlUtil.esc(st)%><%if("waitlisted".equals(st)){%> #<%=e.get("Waitlist_Position")%><%}%></span></td><td><%if(!"cancelled".equals(st)){%><form method="post" action="signup"><input type="hidden" name="eventId" value="<%=e.get("Event_ID")%>"><input type="hidden" name="action" value="cancel"><input type="hidden" name="returnTo" value="my-events"><button class="btn danger">Cancel</button></form><%}else{%><span class="muted">—</span><%}%></td></tr><%}else{%><tr><td colspan="6" class="empty">You have not signed up for an event yet.</td></tr><%}%></tbody></table></div></main></body></html>
