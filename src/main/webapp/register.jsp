<%@ page import="util.HtmlUtil" %><%@ page contentType="text/html;charset=UTF-8" %>
<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Register | CampusConnect</title><link rel="stylesheet" href="css/style.css"></head><body><nav class="nav"><a class="brand" href="index.jsp"><img src="images/sjsu-mark.svg" alt="SJSU"><span>Campus<b>Connect</b></span></a><div class="nav-links"><a href="index.jsp">Home</a><a href="events.jsp">Events</a><a href="login.jsp">Log in</a></div></nav><main class="form-shell"><div class="form-card"><div class="eyebrow" style="color:#0b4f9c">Join the community</div><h1>Create your student account</h1><p class="muted">Use your SJSU email. Passwords are stored using BCrypt hashing.</p><%if(request.getAttribute("error")!=null){%><div class="flash error"><%=HtmlUtil.esc(request.getAttribute("error"))%></div><%}%><form method="post" action="register"><div class="form-row"><div><label class="label">First name</label><input name="firstName" required></div><div><label class="label">Last name</label><input name="lastName" required></div></div><label class="label">SJSU email</label><input type="email" name="email" placeholder="you@sjsu.edu" required><label class="label">Password</label><input type="password" name="password" minlength="8" required><div class="form-row"><div><label class="label">Major</label><input name="major"></div><div><label class="label">Graduation year</label><input type="number" name="gradYear" min="2025" max="2035"></div></div><button class="btn" style="width:100%;margin-top:20px">Create account</button></form><p style="text-align:center;margin-top:18px">Already registered? <a href="login.jsp"><b>Log in</b></a></p></div></main></body></html>
